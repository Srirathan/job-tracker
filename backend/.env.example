# Copy to .env (exact filename) next to this file. The API loads backend/.env only.
#
# If DATABASE_URL is unset: local dev uses sqlite:///./app.db; on Render (RENDER=true) uses sqlite:////data/app.db.
# You can still set DATABASE_URL explicitly, e.g. on Render with a persistent disk:
# DATABASE_URL=sqlite:////data/app.db

DATABASE_URL=sqlite:///./app.db
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Google OAuth (Web application client). Gmail + Sheets use the same refresh token after reconnect.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/api/gmail/oauth/callback
FRONTEND_URL=http://localhost:5173

# Target spreadsheet (optional until you use Sheets). Share with the Google account used for Gmail OAuth.
GOOGLE_SHEET_ID=

# Gmail sync: only list messages newer than this many days (Gmail newer_than:Xd). Default 31.
# GMAIL_SYNC_NEWER_THAN_DAYS=31

# Gemini — required for extract-on-sync (see README).
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
