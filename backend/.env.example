# Copy to .env (exact filename) next to this file. The API loads backend/.env only.

DATABASE_URL=sqlite:///./app.db
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Google OAuth (Web application client). Gmail + Sheets use the same refresh token after reconnect.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/api/gmail/oauth/callback
FRONTEND_URL=http://localhost:5173

# Target spreadsheet for POST /api/sheets/sync. Create a sheet with a tab named "Applications".
# Share the spreadsheet with the Google account you use for Gmail OAuth, or keep it owned by that account.
GOOGLE_SHEET_ID=

# Gmail sync: only list messages newer than this many days (Gmail query newer_than:Xd). Default 31.
# GMAIL_SYNC_NEWER_THAN_DAYS=31
