# Copy to .env (exact filename) next to this file. The API loads backend/.env only.
#
# Local: SQLite file next to cwd. Production (e.g. Render): set DATABASE_URL to your Supabase Postgres URI
# (postgres:// is rewritten to postgresql:// automatically in config).

DATABASE_URL=sqlite:///./app.db
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Google OAuth (Web application client). Gmail + Sheets use the same refresh token after reconnect.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/api/gmail/oauth/callback
# Include scheme. Production: https://your-app.vercel.app (not just the hostname — see README).
FRONTEND_URL=http://localhost:5173

# Target spreadsheet (optional until you use Sheets). Share with the Google account used for Gmail OAuth.
GOOGLE_SHEET_ID=

# Gmail sync: only list messages newer than this many days (Gmail newer_than:Xd). Default 31.
# GMAIL_SYNC_NEWER_THAN_DAYS=31

# Groq — used for extract-on-sync (see README). Free tier ~30 RPM; tune GROQ_DELAY_SECONDS if needed.
GROQ_API_KEY=
# GROQ_DELAY_SECONDS=2
